---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'luka2chat - Independent Developer',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Independent Developer"
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'View Projects',
        href: 'https://github.com/luka2chat',
        icon: 'tabler:arrow-right',
      },
      { text: 'Learn more', href: '#features' },
    ]}
  >
    <Fragment slot="title">
      Building Innovative<br class="hidden sm:inline" /> AI & Software Solutions
    </Fragment>

    <Fragment slot="subtitle">
      An independent developer who crafts products that bring creative ideas to life through code, design, and technology.
    </Fragment>
  </Hero>

  <Features2
    title="About luka2chat"
    subtitle="I specialize in leveraging AI technology and innovative thinking to provide custom software development, mobile applications, and web solutions. With years of experience, I've built applications and tools that solve real-world problems — always with a focus on quality, user experience, and technical excellence."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Features2>

  <Stats
    title="Development Impact"
    subtitle="The numbers below showcase the scale and reach of the independent products I've developed."
    stats={[
      { title: 'Products Created', amount: '25+' },
      { title: 'Active Users', amount: '50K+' },
      { title: 'Code Commits', amount: '2.5K' },
      { title: 'Years Experience', amount: '8+' },
    ]}
  />

  <Brands
    title="Tech Stack"
    subtitle="The technologies and platforms I work with daily."
    icons={['tabler:brand-react', 'tabler:brand-vue', 'tabler:brand-nodejs', 'tabler:brand-typescript', 'tabler:brand-python', 'tabler:brand-flutter', 'tabler:brand-docker', 'tabler:brand-tailwind', 'tabler:brand-firebase']}
    images={[]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Brands>

  <Features2
    title="What services do I provide?"
    subtitle="A comprehensive range of development services to bring your ideas to life and solve complex technical challenges."
    items={[
      {
        title: 'Custom Software Development',
        description:
          'Building tailored applications and software solutions that meet your specific business needs and requirements.',
        icon: 'flat-color-icons:document',
      },
      {
        title: 'Mobile App Development',
        description:
          'Creating native and cross-platform mobile applications for iOS and Android with modern frameworks and best practices.',
        icon: 'flat-color-icons:template',
      },
      {
        title: 'Web Development & Consulting',
        description:
          'Providing expert guidance and development services for web applications, from concept to deployment and maintenance.',
        icon: 'flat-color-icons:voice-presentation',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Features2>

  <Features
    id="features"
    title="Core Development Principles"
    subtitle="The key principles that guide my approach to building high-quality, maintainable, and user-focused products."
    columns={3}
    items={[
      {
        title: 'Clean & Maintainable Code',
        description:
          'Writing code that is not only functional but also clean, well-documented, and easy to maintain for long-term success.',
        icon: 'tabler:artboard',
      },
      {
        title: 'User-Centered Design',
        description: 'Prioritizing user experience and interface design to create intuitive and engaging applications.',
        icon: 'tabler:picture-in-picture',
      },
      {
        title: 'Scalable Architecture',
        description:
          'Building applications with scalable architecture that can grow with your business needs and user base.',
        icon: 'tabler:adjustments-horizontal',
      },
      {
        title: 'Performance Optimization',
        description: 'Ensuring fast loading times and optimal performance across all devices and platforms.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Security Best Practices',
        description:
          'Implementing robust security measures to protect user data and maintain application integrity.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Continuous Innovation',
        description: 'Staying updated with the latest technologies and trends to deliver cutting-edge solutions.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <FAQs
    title="Frequently Asked Questions"
    items={[
      {
        title: 'What types of products have you developed?',
        description:
          'I have developed a wide range of products including mobile applications, web platforms, productivity tools, e-commerce solutions, and custom business software. Each product is tailored to solve specific problems and meet unique user needs.',
      },
      {
        title: 'How do you approach new projects?',
        description:
          'I follow a collaborative approach that starts with understanding your requirements, planning the architecture, developing iteratively with regular feedback, and ensuring quality through testing before deployment.',
      },
      {
        title: 'Can you work on existing projects?',
        description:
          'Yes, I can help improve, maintain, or extend existing projects. I can review code, fix issues, add new features, or help migrate to newer technologies.',
      },
      {
        title: 'What technologies do you specialize in?',
        description:
          'I work with modern web technologies (React, Vue, Node.js), mobile development (React Native, Flutter), databases, cloud services, and various APIs. I choose the best technology stack for each project.',
      },
      {
        title: 'How do you ensure project quality?',
        description:
          'Quality is ensured through comprehensive testing, code reviews, performance optimization, security audits, and ongoing maintenance. I also provide documentation and support for smooth project handover.',
      },
      {
        title: 'What is your development process?',
        description:
          "My process includes requirement analysis, design planning, development sprints, regular client communication, testing phases, and deployment. I maintain transparency throughout the project lifecycle.",
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </FAQs>

  <Features3
    title="Let's discuss your project"
    subtitle="I'm here to help bring your ideas to life and answer any questions about development services."
    columns={3}
    items={[
      {
        title: 'Email',
        icon: 'tabler:mail',
        callToAction: {
          target: '_blank',
          text: 'Write to me',
          href: '/contact',
          variant: 'link',
        },
      },
      {
        title: 'GitHub',
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'View my code',
          href: 'https://github.com/luka2chat',
          variant: 'link',
        },
      },
      {
        title: 'Blog',
        icon: 'tabler:notebook',
        callToAction: {
          text: 'Read my thoughts',
          href: '/blog',
          variant: 'link',
        },
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'View Projects',
        href: 'https://github.com/luka2chat',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">Ready to start your project?</Fragment>

    <Fragment slot="subtitle">
      Let's collaborate to turn your ideas into reality. I'm here to help you build innovative solutions that make a difference.
    </Fragment>
  </CallToAction>
</Layout>
