---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'luka2chat - Independent Developer',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Coding for fun!"
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'GitHub',
        href: 'https://github.com/luka2chat',
        icon: 'tabler:brand-github',
      },
      { text: 'My Projects', href: '#projects' },
    ]}
  >
    <Fragment slot="title">
      Hey, I'm Luka<br class="hidden sm:inline" /> — Building Tools for AI & GEO
    </Fragment>

    <Fragment slot="subtitle">
      Independent developer focused on game data tracking, generative engine optimization, and LLM-powered applications. Always learning, always building.
    </Fragment>
  </Hero>

  <Features2
    id="projects"
    title="What I'm Building"
    subtitle="Open-source projects I'm actively working on — from curated resource lists to gamified tracking systems."
    items={[
      {
        title: 'awesome-geo',
        description:
          'A curated list of 120+ resources for Generative Engine Optimization (GEO) — optimizing content for AI search engines like ChatGPT, Perplexity, Claude, and Google AI Overviews. 17 stars on GitHub.',
        icon: 'tabler:star',
      },
      {
        title: 'ClawRecord',
        description:
          'Gamified OpenClaw tracking system — like Duolingo for your AI assistant. Features XP, levels, achievements, skill trees, daily quests, and a global leaderboard. Built with Python and Node.js.',
        icon: 'tabler:device-gamepad-2',
      },
      {
        title: 'ClawRecord Leaderboard',
        description:
          'Decentralized global leaderboard for OpenClaw tamers — ranking users worldwide with competitive leagues from Bronze to Diamond.',
        icon: 'tabler:chart-bar',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Features2>

  <Stats
    title="GitHub Activity"
    stats={[
      { title: 'Public Repos', amount: '9' },
      { title: 'Stars Earned', amount: '17' },
      { title: 'Contributions', amount: '81' },
      { title: 'Open Source Projects', amount: '3' },
    ]}
  />

  <Brands
    title="Tech Stack"
    subtitle="The technologies I use to build things."
    icons={['tabler:brand-typescript', 'tabler:brand-javascript', 'tabler:brand-python', 'tabler:brand-nodejs', 'tabler:brand-react', 'tabler:brand-tailwind', 'tabler:brand-github', 'tabler:brand-vite']}
    images={[]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Brands>

  <Features
    id="features"
    title="What I Focus On"
    subtitle="The areas where I spend most of my time exploring and building."
    columns={3}
    items={[
      {
        title: 'Generative Engine Optimization',
        description:
          'Researching and curating the best practices for optimizing content visibility in AI-powered search engines and LLM-based answer engines.',
        icon: 'tabler:search',
      },
      {
        title: 'LLM-Powered Applications',
        description:
          'Building tools and applications that leverage large language models to solve real problems — automating workflows and creating smarter developer experiences.',
        icon: 'tabler:brain',
      },
      {
        title: 'Gamification Systems',
        description:
          'Designing engagement mechanics like XP, levels, achievements, and leaderboards to make developer tools more fun to use.',
        icon: 'tabler:trophy',
      },
      {
        title: 'Open Source',
        description:
          'Contributing to and maintaining open-source projects. Everything I build is public and open for collaboration.',
        icon: 'tabler:git-fork',
      },
      {
        title: 'Web Development',
        description:
          'Full-stack web development with modern frameworks — Astro, React, VitePress, Node.js, and more.',
        icon: 'tabler:code',
      },
      {
        title: 'Developer Tools',
        description:
          'Building tools that make developers\' lives easier — from automation scripts to tracking dashboards.',
        icon: 'tabler:tool',
      },
    ]}
  />

  <FAQs
    title="FAQ"
    items={[
      {
        title: 'What is awesome-geo?',
        description:
          'awesome-geo is a curated list of 120+ resources for Generative Engine Optimization (GEO). It covers research papers, tools, strategies, and best practices for optimizing content to be cited by AI search engines like ChatGPT, Perplexity, and Google AI Overviews.',
      },
      {
        title: 'What is ClawRecord?',
        description:
          'ClawRecord is a gamified tracking system for OpenClaw — think of it as Duolingo for your AI assistant. It automatically tracks your OpenClaw usage and turns it into XP, levels, achievements, and a global leaderboard. Built with Python and Node.js.',
      },
      {
        title: 'Are your projects open source?',
        description:
          'Yes! All my projects are open source and available on GitHub. I believe in building in public and collaborating with the community. Feel free to star, fork, or contribute.',
      },
      {
        title: 'What tech stack do you use?',
        description:
          'I primarily work with TypeScript, JavaScript, Python, and Node.js. For web projects I use Astro, React, VitePress, and Tailwind CSS. For backend and automation, Python and GitHub Actions are my go-to tools.',
      },
      {
        title: 'Can I contribute to your projects?',
        description:
          'Absolutely! All my projects welcome contributions. Check out the issues on any of my GitHub repos, or open a PR. For awesome-geo, you can submit new resources. For ClawRecord, feature requests and bug reports are always appreciated.',
      },
      {
        title: 'How can I reach you?',
        description:
          'The best way to reach me is through GitHub — open an issue or start a discussion on any of my repos. You can also find me through the contact page on this site.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </FAQs>

  <Features3
    title="Get in Touch"
    subtitle="Want to collaborate or just say hi?"
    columns={3}
    items={[
      {
        title: 'GitHub',
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'Follow me',
          href: 'https://github.com/luka2chat',
          variant: 'link',
        },
      },
      {
        title: 'Blog',
        icon: 'tabler:notebook',
        callToAction: {
          text: 'Read my posts',
          href: '/blog',
          variant: 'link',
        },
      },
      {
        title: 'Contact',
        icon: 'tabler:mail',
        callToAction: {
          text: 'Send a message',
          href: '/contact',
          variant: 'link',
        },
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'Star awesome-geo',
        href: 'https://github.com/luka2chat/awesome-geo',
        icon: 'tabler:star',
      },
    ]}
  >
    <Fragment slot="title">Check out awesome-geo</Fragment>

    <Fragment slot="subtitle">
      A curated list of 120+ resources for Generative Engine Optimization. If you find it useful, give it a star on GitHub!
    </Fragment>
  </CallToAction>
</Layout>
