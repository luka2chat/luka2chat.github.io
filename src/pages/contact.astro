---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact - luka2chat',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Contact" title="Let's Connect!" subtitle="Have a question, want to collaborate, or just want to say hi? I'd love to hear from you." />

  <ContactUs
    id="form"
    title="Send me a message"
    subtitle="I'll get back to you as soon as I can. For project-specific questions, consider opening a GitHub issue — it helps others who might have the same question."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Message',
    }}
    disclaimer={{
      label:
        'By submitting this form, you agree to the collection of your contact information for the purpose of responding to your message.',
    }}
    description="I typically respond within a few days."
  />

  <Features2
    title="Other Ways to Reach Me"
    items={[
      {
        title: 'GitHub Issues',
        description:
          'For project-related questions, bugs, or feature requests, the best way is to open an issue on the relevant repository.',
        icon: 'tabler:brand-github',
      },
      {
        title: 'GitHub Discussions',
        description:
          'For broader conversations, ideas, or just to chat about GEO, AI, or open source, start a discussion on my repos.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Blog',
        description: 'Check out my blog for articles on GEO, AI tools, and what I\'m building. Comments and feedback are always welcome.',
        icon: 'tabler:notebook',
      },
    ]}
  />
</Layout>
