---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About - luka2chat',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="About me"
  >
    <Fragment slot="title">
      Indie Maker<br class="hidden sm:inline" /> Building in Public
    </Fragment>

    <Fragment slot="subtitle">
      I'm Luka — an indie maker who ships open-source tools around AI, generative engine optimization, and gamification. Everything lives on GitHub, from day one.
    </Fragment>
  </Hero>

  <Stats
    title="By the Numbers"
    stats={[
      { title: 'Public Repos', amount: '9' },
      { title: 'Stars Earned', amount: '17' },
      { title: 'Contributions', amount: '81' },
      { title: 'Projects Contributed To', amount: '2' },
    ]}
  />

  <Features3
    title="Active Projects"
    subtitle="What I'm currently working on and contributing to."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'awesome-geo',
        description:
          'A curated list of 120+ resources for Generative Engine Optimization — helping content creators get cited by AI search engines. My most-starred project.',
        icon: 'tabler:star',
      },
      {
        title: 'ClawRecord',
        description:
          'Gamified OpenClaw tracking with XP, levels, achievements, and a global leaderboard. Built with Python and Node.js.',
        icon: 'tabler:device-gamepad-2',
      },
      {
        title: 'geo-skills',
        description:
          'Production-grade GEO best practices skill for AI coding agents — 12 rule files covering content strategy, technical implementation, and authority building.',
        icon: 'tabler:robot',
      },
    ]}
  />

  <Steps2
    title="What Drives Me"
    subtitle="The principles behind how I build and what I choose to work on."
    items={[
      {
        title: 'Build in public',
        description:
          'Everything I make is open source from day one. I share my progress, learn from the community, and welcome contributions.',
      },
      {
        title: 'Solve real problems',
        description:
          'I build tools that I actually need — whether it\'s curating GEO resources or gamifying AI assistant usage tracking.',
      },
      {
        title: 'Keep it fun',
        description:
          'Coding for fun is my motto. Gamification, creative side projects, and exploring new tech keep me motivated and productive.',
      },
    ]}
  />

  <Steps2
    title="What I've Built"
    subtitle="My own open-source projects on GitHub."
    isReversed={true}
    callToAction={{
      text: 'View my GitHub',
      href: 'https://github.com/luka2chat',
      target: '_blank',
    }}
    items={[
      {
        title: 'awesome-geo',
        description: 'A curated list of 120+ Generative Engine Optimization resources — my most-starred project with 17 stars.',
        icon: 'tabler:star',
      },
      {
        title: 'ClawRecord',
        description:
          'Gamified OpenClaw tracking with XP, levels, achievements, and a global leaderboard. Built with Python and Node.js.',
        icon: 'tabler:device-gamepad-2',
      },
      {
        title: 'geo-skills',
        description:
          'GEO best practices skill for AI coding agents — 12 rule files with actionable code templates and implementation patterns. Installable via npx skills add.',
        icon: 'tabler:robot',
      },
    ]}
  />

  <Features2
    title="Get in Touch"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'GitHub',
        description:
          'Open an issue or start a discussion on any of my repos. This is the best way to reach me for project-related topics.',
        icon: 'tabler:brand-github',
      },
      {
        title: 'Contact Page',
        description:
          'Send me a message through the contact form on this site for general inquiries or collaboration proposals.',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
