---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'luka2chat - 独立开发者',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Coding for fun!"
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'GitHub',
        href: 'https://github.com/luka2chat',
        icon: 'tabler:brand-github',
      },
      { text: '我的项目', href: '#projects' },
    ]}
  >
    <Fragment slot="title">
      嗨，我是 Luka<br class="hidden sm:inline" /> — 构建 AI & GEO 工具
    </Fragment>

    <Fragment slot="subtitle">
      独立开发者，专注于游戏数据追踪、生成式引擎优化（GEO）和 LLM 驱动的应用。一直在学，一直在造。
    </Fragment>
  </Hero>

  <Features2
    id="projects"
    title="我在做什么"
    subtitle="我正在积极维护的开源项目——从精选资源列表到游戏化追踪系统。"
    items={[
      {
        title: 'awesome-geo',
        description:
          '一个精选的 120+ 生成式引擎优化（GEO）资源列表——帮助优化内容在 ChatGPT、Perplexity、Claude、Google AI Overviews 等 AI 搜索引擎中的可见度。GitHub 上获得 17 颗星。',
        icon: 'tabler:star',
      },
      {
        title: 'ClawRecord',
        description:
          '游戏化 OpenClaw 追踪系统——像 Duolingo 一样追踪你的 AI 助手使用情况。包含经验值、等级、成就、技能树、每日任务和全球排行榜。使用 Python 和 Node.js 构建。',
        icon: 'tabler:device-gamepad-2',
      },
      {
        title: 'ClawRecord Leaderboard',
        description:
          '去中心化全球排行榜——在全球范围内对 OpenClaw 用户进行排名，从青铜到钻石的竞技联赛。',
        icon: 'tabler:chart-bar',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Features2>

  <Stats
    title="GitHub 数据"
    stats={[
      { title: '公开仓库', amount: '9' },
      { title: '获得 Stars', amount: '17' },
      { title: '贡献次数', amount: '81' },
      { title: '开源项目', amount: '3' },
    ]}
  />

  <Brands
    title="技术栈"
    subtitle="我用来造东西的技术。"
    icons={['tabler:brand-typescript', 'tabler:brand-javascript', 'tabler:brand-python', 'tabler:brand-nodejs', 'tabler:brand-react', 'tabler:brand-tailwind', 'tabler:brand-github', 'tabler:brand-vite']}
    images={[]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </Brands>

  <Features
    id="features"
    title="我关注的领域"
    subtitle="我花最多时间探索和构建的方向。"
    columns={3}
    items={[
      {
        title: '生成式引擎优化（GEO）',
        description:
          '研究和整理在 AI 驱动的搜索引擎和 LLM 回答引擎中优化内容可见度的最佳实践。',
        icon: 'tabler:search',
      },
      {
        title: 'LLM 驱动的应用',
        description:
          '构建利用大语言模型解决实际问题的工具和应用——自动化工作流，打造更智能的开发者体验。',
        icon: 'tabler:brain',
      },
      {
        title: '游戏化系统',
        description:
          '设计经验值、等级、成就和排行榜等参与机制，让开发者工具更有趣。',
        icon: 'tabler:trophy',
      },
      {
        title: '开源',
        description:
          '贡献和维护开源项目。我做的所有东西都是公开的，欢迎协作。',
        icon: 'tabler:git-fork',
      },
      {
        title: 'Web 开发',
        description:
          '使用现代框架进行全栈 Web 开发——Astro、React、VitePress、Node.js 等。',
        icon: 'tabler:code',
      },
      {
        title: '开发者工具',
        description:
          '构建让开发者生活更轻松的工具——从自动化脚本到追踪仪表板。',
        icon: 'tabler:tool',
      },
    ]}
  />

  <FAQs
    title="常见问题"
    items={[
      {
        title: '什么是 awesome-geo？',
        description:
          'awesome-geo 是一个精选的 120+ 生成式引擎优化（GEO）资源列表。涵盖研究论文、工具、策略和最佳实践，帮助优化内容以被 ChatGPT、Perplexity、Google AI Overviews 等 AI 搜索引擎引用。',
      },
      {
        title: '什么是 ClawRecord？',
        description:
          'ClawRecord 是 OpenClaw 的游戏化追踪系统——可以理解为 AI 助手版的 Duolingo。它自动追踪你的 OpenClaw 使用情况，转化为经验值、等级、成就和全球排行榜。使用 Python 和 Node.js 构建。',
      },
      {
        title: '你的项目是开源的吗？',
        description:
          '是的！我所有的项目都是开源的，可以在 GitHub 上找到。我相信公开构建和社区协作。欢迎 star、fork 或贡献代码。',
      },
      {
        title: '你用什么技术栈？',
        description:
          '我主要使用 TypeScript、JavaScript、Python 和 Node.js。Web 项目使用 Astro、React、VitePress 和 Tailwind CSS。后端和自动化方面，Python 和 GitHub Actions 是我的首选工具。',
      },
      {
        title: '我可以参与贡献吗？',
        description:
          '当然可以！我所有项目都欢迎贡献。查看 GitHub 仓库中的 issues，或者直接提交 PR。awesome-geo 可以提交新资源，ClawRecord 欢迎功能请求和 bug 报告。',
      },
      {
        title: '怎么联系你？',
        description:
          '最好的方式是通过 GitHub——在我的任何仓库中开 issue 或者发起 discussion。你也可以通过本站的联系页面找到我。',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-surface"></div>
    </Fragment>
  </FAQs>

  <Features3
    title="联系我"
    subtitle="想合作或者打个招呼？"
    columns={3}
    items={[
      {
        title: 'GitHub',
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: '关注我',
          href: 'https://github.com/luka2chat',
          variant: 'link',
        },
      },
      {
        title: '博客',
        icon: 'tabler:notebook',
        callToAction: {
          text: '阅读文章',
          href: '/zh/blog',
          variant: 'link',
        },
      },
      {
        title: '联系',
        icon: 'tabler:mail',
        callToAction: {
          text: '发消息',
          href: '/zh/contact',
          variant: 'link',
        },
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: '给 awesome-geo 点 Star',
        href: 'https://github.com/luka2chat/awesome-geo',
        icon: 'tabler:star',
      },
    ]}
  >
    <Fragment slot="title">看看 awesome-geo</Fragment>

    <Fragment slot="subtitle">
      一个精选的 120+ 生成式引擎优化资源列表。如果觉得有用，在 GitHub 上给个 star 吧！
    </Fragment>
  </CallToAction>
</Layout>
