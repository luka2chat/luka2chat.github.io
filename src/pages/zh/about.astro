---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '关于 - luka2chat',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="关于我"
  >
    <Fragment slot="title">
      独立开发者<br class="hidden sm:inline" /> 公开构建
    </Fragment>

    <Fragment slot="subtitle">
      我是 Luka——一个为了乐趣而编程的独立开发者。我构建专注于 AI、生成式引擎优化和游戏化的开源工具。我做的所有东西都在 GitHub 上公开。
    </Fragment>
  </Hero>

  <Stats
    title="数据一览"
    stats={[
      { title: '公开仓库', amount: '9' },
      { title: '获得 Stars', amount: '17' },
      { title: '贡献次数', amount: '81' },
      { title: '参与贡献的项目', amount: '2' },
    ]}
  />

  <Features3
    title="活跃项目"
    subtitle="我目前正在开发和贡献的项目。"
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'awesome-geo',
        description:
          '精选的 120+ 生成式引擎优化资源列表——帮助内容创作者被 AI 搜索引擎引用。我获得最多 star 的项目。',
        icon: 'tabler:star',
      },
      {
        title: 'ClawRecord',
        description:
          '游戏化 OpenClaw 追踪系统，包含经验值、等级、成就和全球排行榜。使用 Python 和 Node.js 构建。',
        icon: 'tabler:device-gamepad-2',
      },
      {
        title: 'geo-skills',
        description:
          '面向 AI 编程智能体的生产级 GEO 最佳实践技能——12 个规则文件覆盖内容策略、技术实现和权威构建。',
        icon: 'tabler:robot',
      },
    ]}
  />

  <Steps2
    title="驱动力"
    subtitle="指导我构建什么、怎么构建的原则。"
    items={[
      {
        title: '公开构建',
        description:
          '我做的所有东西从第一天起就是开源的。我分享进展，从社区学习，欢迎贡献。',
      },
      {
        title: '解决真实问题',
        description:
          '我构建自己真正需要的工具——无论是整理 GEO 资源，还是游戏化 AI 助手使用追踪。',
      },
      {
        title: '保持有趣',
        description:
          'Coding for fun 是我的座右铭。游戏化、创意副项目和探索新技术让我保持动力和效率。',
      },
    ]}
  />

  <Steps2
    title="我构建的项目"
    subtitle="我在 GitHub 上的开源项目。"
    isReversed={true}
    callToAction={{
      text: '查看 GitHub',
      href: 'https://github.com/luka2chat',
      target: '_blank',
    }}
    items={[
      {
        title: 'awesome-geo',
        description: '精选的 120+ 生成式引擎优化资源列表——我获得最多 star 的项目，有 17 颗星。',
        icon: 'tabler:star',
      },
      {
        title: 'ClawRecord',
        description:
          '游戏化 OpenClaw 追踪系统，包含经验值、等级、成就和全球排行榜。使用 Python 和 Node.js 构建。',
        icon: 'tabler:device-gamepad-2',
      },
      {
        title: 'geo-skills',
        description:
          '面向 AI 编程智能体的 GEO 最佳实践技能——12 个规则文件，包含可执行的代码模板和实现模式。通过 npx skills add 安装。',
        icon: 'tabler:robot',
      },
    ]}
  />

  <Features2
    title="联系我"
    tagline="联系方式"
    columns={2}
    items={[
      {
        title: 'GitHub',
        description:
          '在我的任何仓库中开 issue 或者发起 discussion。这是联系我讨论项目相关话题的最好方式。',
        icon: 'tabler:brand-github',
      },
      {
        title: '联系页面',
        description:
          '通过本站的联系表单给我发消息，适合一般咨询或合作提议。',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
