---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: '联系 - luka2chat',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="联系我" title="一起聊聊！" subtitle="有问题、想合作、或者只是打个招呼？我很乐意收到你的消息。" />

  <ContactUs
    id="form"
    title="给我发消息"
    subtitle="我会尽快回复。如果是项目相关的问题，建议在 GitHub 上开 issue——这也能帮到其他有同样问题的人。"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: '姓名',
      },
      {
        type: 'email',
        name: 'email',
        label: '邮箱',
      },
    ]}
    textarea={{
      label: '消息',
    }}
    disclaimer={{
      label:
        '提交此表单即表示您同意收集您的联系信息，用于回复您的消息。',
    }}
    description="我通常会在几天内回复。"
  />

  <Features2
    title="其他联系方式"
    items={[
      {
        title: 'GitHub Issues',
        description:
          '项目相关的问题、bug 或功能请求，最好的方式是在对应仓库中开 issue。',
        icon: 'tabler:brand-github',
      },
      {
        title: 'GitHub Discussions',
        description:
          '更广泛的对话、想法，或者聊聊 GEO、AI 和开源，可以在我的仓库中发起 discussion。',
        icon: 'tabler:message-circle',
      },
      {
        title: '博客',
        description: '看看我的博客，了解 GEO、AI 工具和我正在构建的东西。欢迎评论和反馈。',
        icon: 'tabler:notebook',
      },
    ]}
  />
</Layout>
