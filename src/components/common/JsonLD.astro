---
import { SITE } from 'astrowind:config';

const { metadata } = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Luka2Chat",
  "url": SITE.site,
  "sameAs": [
    "https://github.com/luka2chat"
  ],
  "jobTitle": "Independent Developer",
  "description": "Independent developer focused on generative engine optimization, game data tracking, and LLM-powered applications.",
  "knowsAbout": ["Generative Engine Optimization", "AI", "LLM", "Open Source", "Web Development"]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": SITE.name,
  "url": SITE.site,
  "description": "Independent Developer Portfolio: Explore innovative software development, AI tools, and solutions to enhance your digital experience.",
  "author": { "@type": "Person", "name": "Luka2Chat" },
  "inLanguage": ["en", "zh"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is awesome-geo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "awesome-geo is a curated list of 120+ resources for Generative Engine Optimization (GEO). It covers research papers, tools, strategies, and best practices for optimizing content to be cited by AI search engines like ChatGPT, Perplexity, and Google AI Overviews."
      }
    },
    {
      "@type": "Question",
      "name": "What is ClawRecord?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ClawRecord is a gamified tracking system for OpenClaw — think of it as Duolingo for your AI assistant. It automatically tracks your OpenClaw usage and turns it into XP, levels, achievements, and a global leaderboard. Built with Python and Node.js."
      }
    },
    {
      "@type": "Question",
      "name": "Are your projects open source?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! All my projects are open source and available on GitHub. I believe in building in public and collaborating with the community. Feel free to star, fork, or contribute."
      }
    },
    {
      "@type": "Question",
      "name": "Can I contribute to your projects?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely! All my projects welcome contributions. Check out the issues on any of my GitHub repos, or open a PR. For awesome-geo, you can submit new resources. For ClawRecord, feature requests and bug reports are always appreciated."
      }
    }
  ]
};

const schemas = [personSchema, websiteSchema, faqSchema];
---

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
