---
import { SITE } from 'astrowind:config';

const { metadata } = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Luka2Chat",
  "alternateName": "Luka",
  "url": SITE.site,
  "description": "Independent developer focused on generative engine optimization (GEO), AI-powered applications, and gamification systems. All projects are open source.",
  "sameAs": [
    "https://github.com/luka2chat",
    "https://twitter.com/luka2chat"
  ],
  "jobTitle": "Independent Developer",
  "knowsAbout": [
    "Generative Engine Optimization",
    "AI Search Optimization",
    "Large Language Models",
    "Web Development",
    "TypeScript",
    "Python",
    "React",
    "Astro",
    "Gamification",
    "Open Source Software"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Self-Employed"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Luka2Chat",
  "alternateName": "Luka2Chat - Independent Developer",
  "url": SITE.site,
  "description": "Independent developer portfolio: open-source tools for AI, generative engine optimization, and gamification systems.",
  "author": {
    "@type": "Person",
    "name": "Luka2Chat",
    "url": SITE.site
  },
  "inLanguage": ["en", "zh"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is awesome-geo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "awesome-geo is a curated list of 120+ resources for Generative Engine Optimization (GEO). It covers research papers, tools, strategies, and best practices for optimizing content to be cited by AI search engines like ChatGPT, Perplexity, and Google AI Overviews."
      }
    },
    {
      "@type": "Question",
      "name": "What is ClawRecord?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ClawRecord is a gamified OpenClaw tracking system — like Duolingo for your AI assistant. It automatically tracks OpenClaw usage and turns it into XP, levels, achievements, and a global leaderboard. Built with Python and Node.js."
      }
    },
    {
      "@type": "Question",
      "name": "What types of products has Luka2Chat developed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Luka2Chat develops open-source tools focused on AI and GEO, including awesome-geo (a curated GEO resource list), ClawRecord (gamified AI tracking), and ClawRecord Leaderboard (decentralized competitive ranking). All projects are available on GitHub."
      }
    },
    {
      "@type": "Question",
      "name": "What technologies does Luka2Chat specialize in?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Luka2Chat works with TypeScript, JavaScript, Python, Node.js, React, Astro, Tailwind CSS, and Vite. Focus areas include generative engine optimization, LLM-powered applications, and gamification systems."
      }
    },
    {
      "@type": "Question",
      "name": "Are Luka2Chat's projects open source?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, all projects are open source and available on GitHub. Luka2Chat believes in building in public and welcomes contributions from the community."
      }
    },
    {
      "@type": "Question",
      "name": "What is Generative Engine Optimization (GEO)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Generative Engine Optimization (GEO) is an optimization strategy for improving content visibility in AI-powered search engines and LLM-based answer engines such as ChatGPT, Perplexity, Claude, and Google AI Overviews. Unlike traditional SEO, GEO focuses on being cited by AI through authority, structured data, and factual accuracy."
      }
    }
  ]
};

const schemas = [personSchema, websiteSchema, faqSchema];
---

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
