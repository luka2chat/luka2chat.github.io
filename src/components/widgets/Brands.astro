---
import { Icon } from 'astro-icon/components';
import type { Brands as Props } from '~/types';

import Image from '~/components/common/Image.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
const {
  title = '',
  subtitle = '',
  tagline = '',
  icons = [],
  images = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <div class="flex flex-wrap gap-8 sm:gap-12 lg:gap-16">
    {
      icons &&
        icons.map((icon, index) => (
          <div
            class="flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 text-muted hover:text-heading transition-colors duration-300"
            style={`animation-delay: ${index * 60}ms;`}
          >
            <Icon name={icon} class="w-10 h-10 sm:w-12 sm:h-12" />
          </div>
        ))
    }
    {
      images &&
        images.map(
          (image) =>
            image.src && (
              <div class="flex justify-center col-span-1 my-2 lg:my-4 py-1 px-3 dark:bg-gray-200">
                <img src={image.src} alt={image.alt || ''} class="max-h-12" width={120} height={48} />
              </div>
            )
        )
    }
  </div>
</WidgetWrapper>
