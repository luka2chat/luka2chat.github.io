---
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Faqs as Props } from '~/types';

const {
  title = '',
  subtitle = '',
  tagline = '',
  items = [],
  columns = 1,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-4xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline
    title={title}
    subtitle={subtitle}
    tagline={tagline}
    classes={{
      title: 'text-3xl md:text-4xl font-heading',
    }}
  />
  <div class="space-y-0">
    {
      items.map(({ title, description }) => (
        <details class="group border-t border-subtle last:border-b">
          <summary class="flex items-center justify-between cursor-pointer py-6 text-heading font-medium text-base md:text-lg select-none list-none [&::-webkit-details-marker]:hidden">
            <span>{title}</span>
            <span class="text-muted ml-4 flex-shrink-0 text-xl transition-transform duration-200 group-open:rotate-45">+</span>
          </summary>
          <div class="pb-6 text-muted leading-relaxed pr-8">
            <Fragment set:html={description} />
          </div>
        </details>
      ))
    }
  </div>
</WidgetWrapper>
