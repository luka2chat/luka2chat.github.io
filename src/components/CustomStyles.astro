---
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable', ui-sans-serif, system-ui, sans-serif;
    --aw-font-serif: 'Playfair Display Variable', Georgia, 'Times New Roman', ui-serif, serif;
    --aw-font-heading: 'Playfair Display Variable', Georgia, ui-serif, serif;

    --aw-color-primary: oklch(55% 0.22 350);
    --aw-color-secondary: oklch(45% 0.2 350);
    --aw-color-accent: oklch(55% 0.22 350);

    --aw-color-text-heading: oklch(12% 0.005 260);
    --aw-color-text-default: oklch(25% 0.005 260);
    --aw-color-text-muted: oklch(45% 0.008 260);
    --aw-color-bg-page: oklch(99% 0.002 260);

    --aw-color-bg-page-dark: oklch(12% 0.015 260);

    --aw-color-surface: oklch(97% 0.003 260);
    --aw-color-surface-dark: oklch(16% 0.015 260);
    --aw-color-surface-float: oklch(20% 0.015 260);
    --aw-color-border: oklch(92% 0.005 260);
    --aw-color-border-dark: oklch(22% 0.015 260);

    ::selection {
      background-color: oklch(90% 0.08 350);
      color: oklch(15% 0.01 260);
    }
  }

  .dark {
    --aw-color-primary: oklch(72% 0.18 350);
    --aw-color-secondary: oklch(62% 0.16 350);
    --aw-color-accent: oklch(72% 0.18 350);

    --aw-color-text-heading: oklch(96% 0.003 260);
    --aw-color-text-default: oklch(88% 0.005 260);
    --aw-color-text-muted: oklch(65% 0.008 260);
    --aw-color-bg-page: oklch(12% 0.015 260);

    ::selection {
      background-color: oklch(40% 0.15 350);
      color: oklch(95% 0.005 260);
    }
  }
</style>
